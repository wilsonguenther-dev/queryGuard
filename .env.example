# Supabase — your project's URL and anon key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Your app's public URL (used for server-side error logging)
NEXT_PUBLIC_SITE_URL=https://your-app.com

# Optional: Git commit SHA for deploy version correlation
# Netlify sets this automatically as NETLIFY_GIT_COMMIT_SHA
# Vercel sets this as VERCEL_GIT_COMMIT_SHA
NEXT_PUBLIC_DEPLOY_SHA=
