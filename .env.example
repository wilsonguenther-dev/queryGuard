# ── Supabase ──────────────────────────────────────────────────────────────────
# Your QueryGuard Supabase project's URL and anon key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — used server-side ONLY for admin ingestion client
# NEVER expose this in client-side code or commit it to git
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App URL ───────────────────────────────────────────────────────────────────
# The public URL where this QueryGuard dashboard is deployed
NEXT_PUBLIC_SITE_URL=https://your-queryguard.yourdomain.com

# ── Deploy version (optional) ─────────────────────────────────────────────────
# Used for regression correlation — ties issues to a specific deploy
# Netlify sets NETLIFY_GIT_COMMIT_SHA automatically
# Vercel sets VERCEL_GIT_COMMIT_SHA automatically
# You can also set this manually:
NEXT_PUBLIC_DEPLOY_SHA=

# ── SDK Endpoint (for apps instrumenting via the queryguard npm package) ──────
# This is the URL your instrumented apps POST events to
# Default: https://your-queryguard.yourdomain.com/api/ingest
# Set this in your MONITORED APP's .env, not here
# NEXT_PUBLIC_QUERYGUARD_ENDPOINT=https://your-queryguard.yourdomain.com/api/ingest
