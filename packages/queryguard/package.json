{
  "name": "queryguard",
  "version": "0.1.0",
  "description": "Drop-in observability SDK for Supabase apps. Catches silent failures, RLS 403s, slow queries, and regressions.",
  "license": "MIT",
  "author": "Wilson Guenther <wilson@drivia.consulting>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wilsonguenther-dev/queryguard.git"
  },
  "keywords": [
    "supabase",
    "observability",
    "monitoring",
    "error-tracking",
    "postgrest",
    "rls",
    "nextjs",
    "typescript",
    "instrumentation",
    "sdk"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./supabase": {
      "import": "./dist/supabase/index.js",
      "require": "./dist/supabase/index.cjs",
      "types": "./dist/supabase/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "types": "./dist/react/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs",
      "types": "./dist/server/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
